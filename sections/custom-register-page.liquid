<div class="max-w-[1400px] mx-auto px-6 py-20 relative">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
    
    <!-- Left Column: Image -->
    <div class="hidden md:block">
      {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | image_url: width: 1000 }}" 
             alt="{{ section.settings.image.alt }}" 
             class="w-full h-auto object-cover">
      {% else %}
        <div class="w-full aspect-[4/5] bg-gray-100 flex items-center justify-center">
          <p class="text-gray-400">Select Image in Editor</p>
        </div>
      {% endif %}
    </div>

    <!-- Right Column: Form -->
    <div class="max-w-[480px] mx-auto w-full text-center">
      <h1 class="text-[42px] font-bold tracking-tight mb-10 text-black">Create Account</h1>
      
      {% form 'create_customer', id: 'RegisterForm' %}
        {% if form.posted_successfully? %}
          <script>window.location.hash = '#verify';</script>
        {% endif %}

        {% if form.errors %}
          <div class="text-red-600 text-sm mb-4 text-left">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="flex flex-col gap-4">
          <input type="text" name="customer[first_name]" placeholder="First Name" class="w-full p-4 border border-gray-500 text-gray-700 outline-none">
          <input type="text" name="customer[last_name]" placeholder="Last Name" class="w-full p-4 border border-gray-500 text-gray-700 outline-none">
          <input type="email" name="customer[email]" id="RegisterEmail" placeholder="Email" class="w-full p-4 border border-gray-500 text-gray-700 outline-none" required>
          
          <div class="relative">
            <input type="password" name="customer[password]" placeholder="Password" class="w-full p-4 border border-gray-500 text-gray-700 outline-none">
          </div>
          
          <button type="submit" class="w-full bg-[#5d6b59] text-white py-4 mt-2 font-medium text-lg cursor-pointer">
            Register Now
          </button>
        </div>
      {% endform %}

      <div class="mt-8 flex justify-center items-center gap-6 text-lg text-[#333]">
        <p>Already Have An Account?</p>
        <a href="/pages/login" class="text-[#5d6b59] hover:underline font-medium">Log In</a>
      </div>

      <div class="my-8 text-gray-500 text-lg italic text-center">Or</div>

      <!-- Social Icons -->
      <div class="flex justify-center gap-6 mb-10">
        <div class="w-12 h-12 flex items-center justify-center rounded-full border border-gray-200 cursor-pointer">
          <img src="https://cdn-icons-png.flaticon.com/512/0/747.png" class="w-6 h-6" alt="Apple">
        </div>
        <div class="w-12 h-12 flex items-center justify-center rounded-full border border-gray-200 cursor-pointer">
          <img src="https://cdn-icons-png.flaticon.com/512/2991/2991148.png" class="w-6 h-6" alt="Google">
        </div>
        <div class="w-12 h-12 flex items-center justify-center rounded-full border border-gray-200 cursor-pointer">
          <img src="https://cdn-icons-png.flaticon.com/512/124/124010.png" class="w-6 h-6" alt="Facebook">
        </div>
      </div>

      <p class="text-sm text-gray-600 leading-relaxed">
        By Clicking Register Now" you Agree To <a href="#" class="text-[#5d6b59] underline">Terms&Conditions</a> And <a href="#" class="text-[#5d6b59] underline">Privacy Policy</a>.
      </p>
    </div>
  </div>

  <!-- VERIFY EMAIL MODAL (Screen 02) -->
  <div id="VerifyModal" class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/40 backdrop-blur-sm">
    <div class="bg-white p-10 max-w-xl w-full mx-4 relative text-center shadow-2xl">
      <button onclick="closeModal()" class="absolute top-4 left-4 text-2xl text-gray-400 hover:text-black">&times;</button>
      
      <h2 class="text-2xl font-bold mb-6">Verify Your Email Address</h2>
      
      <p class="text-gray-600 mb-8 leading-relaxed">
        We've Sent An Email To <span id="UserEmailDisplay" class="font-bold text-black">your email</span> To Verify Your Email Address And Activate Your Account. The Link In The Email Will Expire In 24 Hours.
      </p>
      
      <p class="text-sm text-gray-500">
        Click Here If You Did Not Receive An Email Or Would Like To Change The Email Address You Registered With.
      </p>
    </div>
  </div>
</div>

<script>
  function closeModal() {
    document.getElementById('VerifyModal').classList.add('hidden');
    window.location.hash = '';
  }

  // Check if we should show the modal on page load
  window.addEventListener('DOMContentLoaded', () => {
    if (window.location.hash === '#verify') {
      const modal = document.getElementById('VerifyModal');
      const emailInput = document.getElementById('RegisterEmail');
      const displayEmail = document.getElementById('UserEmailDisplay');
      
      // Attempt to show the email address used
      if (emailInput && emailInput.value) {
        displayEmail.innerText = emailInput.value;
      }
      
      modal.classList.remove('hidden');
    }
  });
</script>

{% schema %}
{
  "name": "Custom Register",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Display Image"
    }
  ],
  "presets": [{ "name": "Custom Register" }]
}
{% endschema %}