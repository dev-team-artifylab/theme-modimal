<section class="hero-section full-width relative flex items-center overflow-hidden min-h-[390px] lg:min-h-[500px]">
  {%- comment -%} Background Image with Overlay {%- endcomment -%}
  
  <div class="absolute inset-0 z-0">
    {% if section.settings.image != blank %}
      {{
        section.settings.image
        | image_url: width: 2000
        | image_tag:
          class: 'w-full h-full object-cover',
          widths: '375, 550, 750, 1100, 1500, 1780, 2000',
          loading: 'eager',
          alt: section.settings.image.alt
        | default: shop.name
      }}
    {% else %}
      {%- comment -%} Placeholder if no image is uploaded {%- endcomment -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'w-full h-full object-cover bg-gray-200' }}
    {% endif %}

    {%- comment -%} Overlay to make text readable {%- endcomment -%}
    <div class="absolute inset-0 bg-black/30"></div>
  </div>

  {%- comment -%} Content Area {%- endcomment -%}
  <div class="absolute inset-0 z-10 container mx-auto px-6 md:px-18 lg:px-26">
    <div class="flex flex-col justify-end h-full pb-10 md:pb-16 lg:pb-20">
      <div class="max-w-md text-white flex flex-col gap-4">
        {% if section.settings.heading != blank %}
          <h1 class="text-xl md:text-2xl lg:text-[34px] font-normal italic leading-[1.4]">
            {{ section.settings.heading }}
          </h1>
        {% endif %}

        {% if section.settings.button_label != blank %}
          <div>
            <a
              href="{{ section.settings.button_link }}"
              class="inline-block bg-white text-black px-8 py-2 text-sm font-medium uppercase tracking-widest hover:bg-[#5A6D57] hover:text-white transition-all"
            >
              {{ section.settings.button_label }}
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Elegance In Simplicity, Earth's Harmony"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "New In"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}
