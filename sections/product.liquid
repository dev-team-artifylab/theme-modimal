<section class="grid grid-cols-1 gap-4">

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 p-4">

  <!-- ===== Images Column ===== -->
  <div class="images h-[512px] w-full flex gap-6 p-2">

    <!-- Thumbnails -->
    <div class="img_box h-full max-h-[500px] overflow-y-auto flex flex-col gap-4 hidden md:flex">
      {% for image in product.images %}
        <img 
          src="{{ image | image_url: width: 125 }}" 
          data-full="{{ image | image_url: width: 800 }}"
          alt="{{ image.alt | escape }}" 
          class="thumbnail w-[125px] h-[160px] object-cover cursor-pointer"
        >
      {% endfor %}
    </div>

    <!-- Main Image -->
    {% if product.featured_image %}
      <img 
        id="mainImage"
        class="w-full h-full object-cover"
        src="{{ product.featured_image | image_url: width: 800 }}" 
        alt="{{ product.featured_image.alt | escape }}"
      >
    {% else %}
      {{ 'product-1' | placeholder_svg_tag: 'w-full h-[512px] object-cover' }}
    {% endif %}

  </div>

  <!-- ===== Description Column ===== -->
  <div class="description flex flex-col gap-[24px] p-2">
      <h3 class="text-[32px] font-bold">{{ product.title }}</h3>

      <p id="product-desc" class="text-gray-600">
          {% if product.description.size > 200 %}
            <span id="desc-short">{{ product.description | truncate: 200 }}</span>
            <button class="text-primary text-[18px] ml-1">Read More</button>
          {% else %}
            {{ product.description }}
          {% endif %}
      </p>

      <!-- Option Section -->
          {% form 'product', product, class: 'product-form flex flex-col gap-6' %}
            <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}">
            <script id="product-data" type="application/json">
              {{ product | json }}
            </script>

        {% for option in product.options_with_values %}
          <div class="flex flex-col justify-start gap-4 w-full">
            <div class="flex justify-between items-center w-full">
              <h3 class="text-sm sm:text-[16px] text-black font-normal">
                {% if option.name contains 'Color' or option.name contains 'Colour' -%}
                  Colors
                {%- endif %}
              </h3>
              {% if option.name contains 'Size' or option.name contains 'size' %}
                <button type="button" class="text-[14px] text-gray-400 hover:text-black transition-colors">Size Guide</button>
              {% endif %}
            </div>

        <div class="flex flex-wrap items-center gap-3 sm:gap-4 w-full">
          {% if option.name contains 'Color' or option.name contains 'Colour' %}
            {% for value in option.values %}
              <label class="cursor-pointer">
                <input
                  type="radio"
                  name="{{ option.name }}"
                  value="{{ value }}"
                  class="hidden peer"
                  {% if option.selected_value == value %}
                    checked
                  {% endif %}
                >
                {% comment %} Dynamic color mapping logic {% endcomment %}
                {% assign color_val = value | downcase %}
                <span
                  class="color-swatch w-[24px] h-[24px] rounded-full border-2 border-black peer-checked:border-gray-300 peer-checked:[&_svg]:opacity-100 flex items-center justify-center relative transition-all"
                  style="background-color: {{ color_val }};"
                >
                  <svg
                    class="w-5 h-5 text-white opacity-0 transition-opacity pointer-events-none drop-shadow-sm"
                    viewBox="0 0 20 20"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M16 5L7 14L4 11"/>
                  </svg>
                </span>
              </label>
            {% endfor %}
          {% else %}
            <div class="relative w-full">
  <select 
    name="{{ option.name }}" 
    class="w-full h-[40px] px-4 bg-white border border-gray-200 text-h6 text-black font-bold focus:outline-none focus:border-black focus:ring-1 focus:ring-black cursor-pointer transition-colors appearance-none pr-10"
  >
    <option value="" disabled selected class="text-h6 font-bold"> 
      {{ option.name }}
    </option>
    {% for value in option.values %}
      <option value="{{ value }}" class="text-body-md font-bold">
        {{ value }}
      </option>
    {% endfor %}
  </select> 

  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-black">
    <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
      <path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"></path>
    </svg>
  </div>
</div>
          {% endif %}
        </div>
      </div>
    {% endfor %}

    
      <button
        type="submit"
        data-add-to-cart-btn
        {% unless product.available %}
          disabled
        {% endunless %}
        class="bg-[#5A6D57] text-white h-[40px] w-full hover:bg-gray-800 transition disabled:bg-gray-300 cursor-pointer"
      >
        <span class="text-body-sm font-normal">
          {% if product.available %}Add to Cart {{product.price | money}}{% else %}Sold Out{% endif %}
        </span>
      </button>
    
  {% endform %}


      <!-- Delivery Info -->
      <div class="delivery-info flex justify-between p-1">
           <div class="flex gap-4">
              <img src="{{ 'truck.png' | asset_url }}" alt="Free delivery" width="20" height="20" class="w-[20px] h-[20px]">
              <p class="text-[14px]">Free delivery</p>
           </div>
           <div class="flex gap-2">
              <img src="{{ 'heart.png' | asset_url }}" alt="Add to wishlist" width="20" height="20" class="w-[20px] h-[20px]">
              <p class="text-[14px]">Add to wishlist</p>
           </div>
      </div>
  </div>

</div>



{% comment %} FAQ SECTION {% endcomment %}

