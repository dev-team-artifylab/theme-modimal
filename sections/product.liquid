    <!-- ITEM -->
    <div class="border-b border-gray-300 accordion-item">
      <div class="flex justify-between items-center p-4 cursor-pointer header">
        <p class="font-semibold">Product Detail</p>
        <span class="text-xl icon">+</span>
      </div>
      <div class="content hidden px-4 pb-4 text-sm text-gray-600">
        Product details here...
      </div>
    </div>

    <!-- ITEM -->
    <div class="accordion-item">
      <div class="flex justify-between items-center p-4 cursor-pointer header">
        <p class="font-semibold ">Shipping And Return</p>
        <span class="text-xl icon">−</span>
      </div>
      <div class="content px-4 pb-4 text-sm text-gray-600">
        <p>Shipping:<br>is free on US , Canada orders are $175 <br>
        Returns: <br> Unwashed, unworn items are eligible for returns or exchanges within 30 days of purchase. Final Sale items are not eligible for returns or exchanges.</p>
       
      </div>
    </div>

  </div>

  <!-- RIGHT SIDE -->
  <div class="w-1/2 bg-[#F0F2EF] border border-gray-300 p-4 flex flex-col gap-[24px]">
    <h2 class="font-semibold text-lg mb-2 border-b border-gray-300 p-4">Silk</h2>
    <p class="text-sm text-gray-700">
      This material is our signature high-stretch fabric that drapes like silk.
      Soft to touch and eco-certified.
    </p>

    <div class="flex gap-2 mt-4">
      <span class="bg-white px-3 py-1 text-xs">Quick Dry</span>
      <span class="bg-white px-3 py-1 text-xs">Chemical Free</span>
      <span class="bg-white px-3 py-1 text-xs">Machine Washable</span>
    </div>
  </div>

</div>



<!-- Related Products -->
<h1 class="text-2xl font-bold mb-6">You may also like</h1>
<div class="flex flex-wrap gap-6">
  {% assign target_collection = section.settings.collection %}
  {% if target_collection == blank %}
    {% assign target_collection = product.collections.first %}
  {% endif %}

  {% assign shown_count = 0 %}
  {% for related_product in target_collection.products %}
    {% if related_product.handle != product.handle and shown_count < 4 %}
      {% assign shown_count = shown_count | plus: 1 %}
      <div class="w-[320px] bg-white rounded-lg overflow-hidden shadow-md group">

        <!-- Image Section -->
        <div class="relative">
          <a href="{{ related_product.url }}">
            <img 
              src="{{ related_product.featured_image | img_url: 'master' }}" 
              alt="{{ related_product.title | escape }}"
              class="w-full h-[400px] object-cover"
            />
          </a>
          <!-- Wishlist Icon -->
          <button class="absolute top-3 right-3">
            <img src="{{ 'heart.png' | asset_url }}" alt="" class="w-[18px] h-[18px]">
          </button>
        </div>

        <!-- Content -->
        <div class="p-4 pt-3">
          <h2 class="text-[17px] font-bold text-gray-900 leading-tight">
            <a href="{{ related_product.url }}">{{ related_product.title }}</a>
          </h2>
          <div class="flex justify-between items-center mt-1">
            <span class="text-[15px] text-gray-600">
              {% if related_product.type != blank %}{{ related_product.type }}{% else %}{{ related_product.vendor | default: "Turn It Up Dress" }}{% endif %}
            </span>
            <span class="text-[15px] font-bold text-gray-900">
              {{ related_product.price | money }}
            </span>
          </div>
          <!-- Color Options -->
          <div class="flex gap-2 mt-3">
            {% for option in related_product.options_with_values %}
              {% if option.name == 'Color' or option.name == 'Colour' %}
                {% for value in option.values limit: 4 %}
                  <div class="w-5 h-5 rounded-full border border-gray-200" style="background-color: {{ value | downcase | remove: ' ' }};" title="{{ value }}"></div>
                {% endfor %}
              {% endif %}
            {% endfor %}
          </div>
        </div>

      </div>
    {% endif %}
  {% endfor %}
</div>

</section>

<!-- Quick Cart Overlay -->
<div id="quick_cart_overlay" class="fixed inset-0 bg-black/50 backdrop-blur-[2px] z-40 hidden opacity-0 transition-opacity"></div>

<!-- Quick Cart Drawer -->
<section id="quick_cart" class="fixed top-[120px] right-0 h-[calc(100vh-120px)] w-[600px] bg-background z-50 transform translate-x-full transition-transform flex flex-col">
  <!-- Header -->
  <div class="flex justify-center items-center p-6 shrink-0">
    <h2 class="text-h5 font-bold text-gray-900">Your Cart</h2>
  </div>

  <!-- Scrollable Content -->
  <div class="flex-1 overflow-y-auto flex flex-col">
    <!-- Cart Items -->
    <div id="quick-cart-items" class="p-6 flex flex-col gap-6">
      <div class="flex items-center justify-center py-10 text-gray-500">Your cart is empty.</div>
    </div>

    <!-- Footer -->
    <div class="p-6 pt-0 flex justify-center items-center">
      <a href="{{ routes.cart_url }}" 
        class="w-[392px] h-[40px] bg-[#5A6D57] text-white text-center text-body-sm hover:bg-gray-800 transition cursor-pointer flex items-center justify-center">
        Go to Cart
      </a>
    </div>
  </div>
</section>



{% schema %}
{
  "name": "Product",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ]
}
{% endschema %}
<script>
  document.addEventListener("DOMContentLoaded", function () {
    const productForm = document.querySelector('.product-form');
    if (!productForm) return;

    const productDataEl = document.getElementById('product-data');
    if (!productDataEl) return;

    let productData;
    try {
      productData = JSON.parse(productDataEl.textContent);
    } catch (e) {
      console.warn('Product JSON parse error:', e);
      return;
    }

    const variantIdInput = document.getElementById('variant-id');
    const addToCartBtn = productForm.querySelector('[data-add-to-cart-btn]');
    const addToCartText = productForm.querySelector('[data-add-to-cart-text]');
    const mainImage = document.getElementById('mainImage');
    const thumbnails = document.querySelectorAll('.thumbnail');

    // Quick Cart Drawer Logic
    const quickCartOverlay = document.getElementById('quick_cart_overlay');
    const quickCart = document.getElementById('quick_cart');
    const closeQuickCart = document.getElementById('close-quick-cart');
    const quickCartItems = document.getElementById('quick-cart-items');
    const quickCartTotal = document.getElementById('quick-cart-total');

    function openCartDrawer() {
      if (!quickCartOverlay || !quickCart) return;
      quickCartOverlay.classList.remove('hidden');
      // trigger reflow
      void quickCartOverlay.offsetWidth;
      quickCartOverlay.classList.remove('opacity-0');
      quickCart.classList.remove('translate-x-full');
      document.body.style.overflow = 'hidden';
    }

    function closeCartDrawer() {
      if (!quickCartOverlay || !quickCart) return;
      quickCartOverlay.classList.add('opacity-0');
      quickCart.classList.add('translate-x-full');
      document.body.style.overflow = '';
      setTimeout(() => {
        quickCartOverlay.classList.add('hidden');
      }, 300);
    }

    if (closeQuickCart) closeQuickCart.addEventListener('click', closeCartDrawer);
    if (quickCartOverlay) quickCartOverlay.addEventListener('click', closeCartDrawer);

    function formatMoney(cents) {
      // Basic formatting
      return '$' + (cents / 100).toFixed(2);
    }

    function renderCartItems(cart) {
      if (quickCartTotal) {
        quickCartTotal.textContent = formatMoney(cart.total_price);
      }
      
      if (!quickCartItems) return;
      
      if (cart.item_count === 0) {
        quickCartItems.innerHTML = '<div class="flex items-center justify-center py-10 text-gray-500">Your cart is empty.</div>';
        return;
      }

      let itemsHtml = '';
      cart.items.forEach(item => {
        const imageUrl = item.image ? item.image : '';
        itemsHtml += `
          <div class="h-[163px] flex gap-4 pb-4">
            ${imageUrl ? `<img src="${imageUrl}" alt="${item.product_title}" class="w-[117px] h-[163px] object-cover">` : '<div class="w-20 h-24"></div>'}
            <div class="flex-1 flex flex-col justify-between">
              <div class="flex flex-col gap-1">
                <div class="flex justify-between items-start">
                  <h3 class="font-bold text-h6 text-gray-900 pr-2">${item.product_title}</h3>
                  <button type="button" class="text-button-sm text-gray-500 hover:text-black transition cursor-pointer" onclick="updateCartItem('${item.key}', 0)" title="Remove item">✕</button>
                </div>
                ${item.options_with_values 
                  ? item.options_with_values.filter(opt => opt.value !== 'Default Title').map(opt => `<h6 class="text-body-sm text-gray-600 mt-1">${opt.name} : ${opt.value}</h6>`).join('') 
                  : (item.variant_title && item.variant_title !== 'Default Title' ? `<p class="text-xs text-gray-800 mt-1">${item.variant_title}</p>` : '')}
              </div>
              <div class="flex justify-between items-center mt-2">
                <div class="flex bg-[#D1D9CF] items-center">
                  <button type="button" class="px-2 py-1 text-gray-500 hover:text-black cursor-pointer" onclick="updateCartItem('${item.key}', ${item.quantity - 1})">-</button>
                  <span class="px-2 text-sm font-medium w-6 text-center">${item.quantity}</span>
                  <button type="button" class="px-2 py-1 text-gray-500 hover:text-black cursor-pointer" onclick="updateCartItem('${item.key}', ${item.quantity + 1})">+</button>
                </div>
                <span class="font-bold text-sm">${formatMoney(item.final_line_price)}</span>
              </div>
            </div>
          </div>
        `;
      });
      quickCartItems.innerHTML = itemsHtml;

      // Update header cart counts
      const desktopCartCount = document.getElementById('desktop-cart-count');
      if (desktopCartCount) {
        desktopCartCount.textContent = cart.item_count;
        if (cart.item_count === 0) {
          desktopCartCount.classList.add('hidden');
        } else {
          desktopCartCount.classList.remove('hidden');
        }
      }
      
      const mobileCartCount = document.getElementById('mobile-cart-count');
      if (mobileCartCount) {
        mobileCartCount.textContent = cart.item_count;
      }
    }

    const routesRoot = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';

    window.updateCartItem = function(key, quantity) {
      fetch(routesRoot + 'cart/change.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          id: String(key),
          quantity: quantity
        })
      })
      .then(response => response.json())
      .then(cart => {
        renderCartItems(cart);
      })
      .catch(error => console.error('Error updating cart:', error));
    };

    // Initial cart fetch
    fetch(routesRoot + 'cart.js')
      .then(response => response.json())
      .then(cart => {
        renderCartItems(cart);
      })
      .catch(error => console.error('Error fetching cart:', error));

    // AJAX Add to Cart
    productForm.addEventListener('submit', function(e) {
      e.preventDefault();
      
      const formData = new FormData(productForm);
      const submitBtn = addToCartBtn;
      const originalHtml = submitBtn ? submitBtn.innerHTML : '';
      
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="text-body-sm font-normal">Adding...</span>';
      }

      fetch(routesRoot + 'cart/add.js', {
        method: 'POST',
        body: formData
      })
      .then(response => response.json())
      .then(item => {
        return fetch(routesRoot + 'cart.js');
      })
      .then(response => response.json())
      .then(cart => {
        renderCartItems(cart);
        openCartDrawer();
      })
      .catch((error) => {
        console.error('Error adding to cart:', error);
      })
      .finally(() => {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalHtml;
        }
      });
    });
    

    // --- Thumbnail switcher ---
    thumbnails.forEach(img => {
      img.addEventListener('click', () => {
        if (mainImage) mainImage.src = img.getAttribute('data-full');
        thumbnails.forEach(i => i.classList.remove('border-black', 'border-2'));
        img.classList.add('border-black', 'border-2');
      });
    });

    // --- Read More / Read Less toggle ---
    const showAllBtn = document.getElementById('show-all');
    const descShort  = document.getElementById('desc-short');
    const descFull   = document.getElementById('desc-full');

    if (showAllBtn) {
      showAllBtn.addEventListener('click', () => {
        const isCollapsed = descFull.classList.contains('hidden');
        if (descShort) descShort.classList.toggle('hidden', isCollapsed);
        if (descFull) descFull.classList.toggle('hidden', !isCollapsed);
        showAllBtn.textContent = isCollapsed ? 'Read Less' : 'Read More';
      });
    }

    // --- Quantity buttons ---
    const qtyInput = productForm.querySelector('input[name="quantity"]');
    const qtyMinus = productForm.querySelector('[data-qty-btn="minus"]');
    const qtyPlus = productForm.querySelector('[data-qty-btn="plus"]');

    if (qtyMinus && qtyInput) {
      qtyMinus.addEventListener('click', () => {
        let val = parseInt(qtyInput.value) || 1;
        if (val > 1) qtyInput.value = val - 1;
      });
    }
    if (qtyPlus && qtyInput) {
      qtyPlus.addEventListener('click', () => {
        let val = parseInt(qtyInput.value) || 1;
        qtyInput.value = val + 1;
      });
    }

    // --- Variant switching logic ---
    function updateVariant() {
      const selectedOptions = [];
      const optionNames = productData.options.map(opt => typeof opt === 'string' ? opt : opt.name || opt);

      optionNames.forEach(optionName => {
        const escapedName = optionName.replace(/"/g, '\\"');
        const checkedRadio = productForm.querySelector(`input[name="${escapedName}"]:checked`);
        const selectBox = productForm.querySelector(`select[name="${escapedName}"]`);
        
        if (checkedRadio) {
          selectedOptions.push(checkedRadio.value);
        } else if (selectBox) {
          selectedOptions.push(selectBox.value);
        } else {
          selectedOptions.push(null);
        }
      });

      // Find the variant
      const matchedVariant = productData.variants.find(variant => {
        return selectedOptions.every((val, index) => {
          return val === variant.options[index];
        });
      });

      if (matchedVariant) {
        // Update variant ID
        if (variantIdInput) variantIdInput.value = matchedVariant.id;

        // Update URL
        if (window.history.replaceState) {
          const url = new URL(window.location);
          url.searchParams.set('variant', matchedVariant.id);
          window.history.replaceState({}, '', url);
        }

        // Update Button
        if (addToCartBtn) {
          addToCartBtn.disabled = !matchedVariant.available;
          if (addToCartText) {
            addToCartText.textContent = matchedVariant.available ? 'Add to Cart' : 'Sold Out';
          }
        }

        // Update Image
        if (matchedVariant.featured_image && mainImage) {
          mainImage.src = matchedVariant.featured_image.src;
          // Sync thumbnail border
          thumbnails.forEach(img => {
            if (img.src.includes(matchedVariant.featured_image.src.split('?')[0])) {
               thumbnails.forEach(i => i.classList.remove('border-black', 'border-2'));
               img.classList.add('border-black', 'border-2');
            }
          });
        }
      }
    }

    productForm.addEventListener('change', function(e) {
      if (e.target.type === 'radio' || e.target.tagName === 'SELECT') {
        updateVariant();
      }
    });

    // Handle clicks on spans/labels acting as radio buttons
    productForm.addEventListener('click', function(e) {
      const label = e.target.closest('label');
      if (label) {
        const input = label.querySelector('input[type="radio"]');
        if (input && !input.checked) {
          input.checked = true;
          // Dispatch change event to trigger updateVariant
          input.dispatchEvent(new Event('change', { bubbles: true }));
        }
      }
    });

    // Initialize variant state on load
    updateVariant();

    // --- FAQ Toggler ---
    const items = document.querySelectorAll('.accordion-item');

    items.forEach(item => {
      const header = item.querySelector('.header');
      const content = item.querySelector('.content');
      const icon = item.querySelector('.icon');

      if (header && content && icon) {
        header.addEventListener('click', () => {
          const isOpen = !content.classList.contains('hidden');

          // CLOSE ALL
          items.forEach(i => {
            const c = i.querySelector('.content');
            const ic = i.querySelector('.icon');
            if (c) c.classList.add('hidden');
            if (ic) ic.textContent = '+';
          });

          // OPEN CURRENT
          if (!isOpen) {
            content.classList.remove('hidden');
            icon.textContent = '−';
          }
        });
      }
    });

  });
</script>