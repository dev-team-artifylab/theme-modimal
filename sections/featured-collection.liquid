<section class="collection-section py-8 px-2 md:px-6 lg:px-8">
  {%- comment -%} Header {%- endcomment -%}
  <div class="flex justify-between items-center py-4">
    <h3 class="text-l md:text-xl lg:text-2xl font-semibold leading-[140%]">{{ section.settings.title | default: 'Collection' }}</h3>
    <a href="{{ routes.collections_url }}" class="text-xs md:text-sm underline underline-offset-4 uppercase tracking-widest">
      {{ section.settings.view_all_label | default: 'View All' }}
    </a>
  </div>

  <div class="flex flex-col md:flex-row gap-2 lg:gap-3">
  
  {%- comment -%} Left Column {%- endcomment -%}
  <div class="flex flex-col w-full md:w-1/2 gap-4 md:gap-8">
    {% render 'collection-item', collection_handle: section.settings.collection_1, aspect_ratio: 'aspect-[6/4.5]' %}
    {% render 'collection-item', collection_handle: section.settings.collection_2, aspect_ratio: 'aspect-[6/7.8]' %}
  </div>

  {%- comment -%} Right Column {%- endcomment -%}
  <div class="flex flex-col w-full md:w-1/2 gap-4 md:gap-12 mt-0 md:mt-6">
    {% render 'collection-item', collection_handle: section.settings.collection_3, aspect_ratio: 'aspect-[6/7.8]' %}
    {% render 'collection-item', collection_handle: section.settings.collection_4, aspect_ratio: 'aspect-[6/3.8]' %}
  </div>
</div>
</section>
{% schema %}
{
  "name": "Featured Collections",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Heading",
      "default": "Collection"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View All Label",
      "default": "View All"
    },
    {
      "type": "header",
      "content": "Collections Layout"
    },
    {
      "type": "collection",
      "id": "collection_1",
      "label": "First Collection (Left Top)"
    },
    {
      "type": "collection",
      "id": "collection_2",
      "label": "Second Collection (Left Bottom)"
    },
    {
      "type": "collection",
      "id": "collection_3",
      "label": "Third Collection (Right Top)"
    },
    {
      "type": "collection",
      "id": "collection_4",
      "label": "Fourth Collection (Right Bottom)"
    }
  ],
  "presets": [
    {
      "name": "Featured Collections"
    }
  ]
}
{% endschema %}