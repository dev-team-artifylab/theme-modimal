<main class="max-w-7xl mx-auto px-4 py-10">
  <!--  SPLIT COLLECTION BANNER -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-16">
    {% if section.settings.banner_image_1 != blank and section.settings.banner_image_2 != blank %}
      <!-- 2 IMAGE MODE -->
      <div class="h-[300px] md:h-[500px] lg:h-[655px] overflow-hidden rounded-lg">
        <img
          src="{{ section.settings.banner_image_1 | image_url: width: 1400 }}"
          class="w-full h-full object-cover"
        >
      </div>

      <div class="h-[300px] md:h-[500px] lg:h-[655px] overflow-hidden rounded-lg">
        <img
          src="{{ section.settings.banner_image_2 | image_url: width: 1400 }}"
          class="w-full h-full object-cover"
        >
      </div>

    {% elsif section.settings.banner_image_1 != blank %}
      <!-- 1 IMAGE MODE -->
      <div class="col-span-2 h-[300px] md:h-[500px] lg:h-[655px] overflow-hidden rounded-lg">
        <img
          src="{{ section.settings.banner_image_1 | image_url: width: 2000 }}"
          class="w-full h-full object-cover"
        >
      </div>
    {% endif %}
  </div>

  <!--  MAIN GRID -->
  <div class="grid grid-cols-[392px_1fr] gap-10 mt-16">
    <!-- Sidebar -->
    <aside class="flex flex-col gap-4">
      {% render 'filter-sidebar' %}
    </aside>

    <!-- Products -->
    <section>
      <!-- Product Grid -->
      <div id="product-grid" class="grid grid-cols-2 gap-6">
        {% if collection.products.size > 0 %}
          {% for product in collection.products %}
            <div class="product-item hidden">
              {% render 'product-card', product: product %}
            </div>
          {% endfor %}

        {% else %}
          <!-- No Products -->
          <div class="col-span-2 text-center py-20">
            <h3 class="text-xl font-semibold text-gray-700">No products found</h3>
            <p class="text-gray-500 mt-2">Try adjusting your filters</p>
          </div>
        {% endif %}
      </div>

      <!-- Load More -->
      <div class="flex justify-center mt-10">
        <button
          id="loadMoreBtn"
          class="px-8 py-3 border border-[#748C70] text-[#748C70] hover:bg-[#748C70] hover:text-white transition cursor-pointer"
        >
          Load More
        </button>
      </div>
    </section>
  </div>
</main>

{% schema %}
{
  "name": "Collection Page",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image_1",
      "label": "Banner Image Left"
    },
    {
      "type": "image_picker",
      "id": "banner_image_2",
      "label": "Banner Image Right"
    }
  ]
}
{% endschema %}
