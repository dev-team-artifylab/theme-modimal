<section class="full-width pl-6 md:pl-12 overflow-hidden py-8">
  <div class="py-4">
    <h3 class="text-l sm:text-xl md:text-2xl lg:text-[24px] font-semibold uppercase tracking-wider">
      {{ section.settings.heading }}
    </h3>
  </div>

  <div class="relative group">
    <div
      class="flex gap-4 overflow-x-auto scroll-smooth snap-x snap-mandatory hide-scrollbar pr-12"
      id="collection-slider-{{ section.id }}"
    >
      {% for block in section.blocks %}
        {% assign collection = collections[block.settings.collection] %}
        
        <div class="flex-shrink-0 snap-start w-[220px] md:w-[240px] xl:w-[288px]" {{ block.shopify_attributes }}>
          
          <div class="relative w-full aspect-[3/4.4] overflow-hidden bg-[#f3f3f3] group/item">
            <a href="?day={{ collection.handle }}" class="block w-full h-full">
              {%- if collection.featured_image -%}
                <img
                  src="{{ collection.featured_image | image_url: width: 800 }}"
                  alt="{{ collection.title | escape }}"
                  loading="lazy"
                  width="{{ collection.featured_image.width }}"
                  height="{{ collection.featured_image.height }}"
                  class="w-full h-full object-cover hover:scale-105 duration-500 transition-transform"
                >
              {% else %}
                {{ 'collection-1' | placeholder_svg_tag: 'w-full h-full object-cover opacity-50' }}
              {% endif %}
            </a>

            <button 
              type="button" 
              class="absolute top-4 right-4 z-10 p-2 rounded-full bg-white/80 backdrop-blur-sm shadow-sm hover:bg-white transition-all duration-300 group-hover/item:opacity-100 md:opacity-0"
              aria-label="Add to wishlist"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 stroke-black fill-none hover:fill-red-500 hover:stroke-red-500 transition-colors" viewBox="0 0 24 24" stroke-width="1.5">
                <path d="M12 21s-7-4.35-9.5-8.28C.5 9.5 2.42 5.5 6.5 5.5c2.28 0 4.1 1.32 5.5 3.09C13.4 6.82 15.22 5.5 17.5 5.5c4.08 0 6 4 4 7.22C19 16.65 12 21 12 21z"></path>
              </svg>
            </button>
          </div>

          <div class="py-4 px-2">
            <h4 class="text-sm md:text-base font-semibold truncate tracking-tight ">
              {{ collection.title | default: "Collection Title" }}
            </h4>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
{% schema %}
{
  "name": "Modiweek Collections",
  "max_blocks": 7,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Our Collections"
    }
  ],
  "blocks": [
    {
      "type": "collection_block",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Modiweek Collections",
      "blocks": [
        { "type": "collection_block" },
        { "type": "collection_block" },
        { "type": "collection_block" },
        { "type": "collection_block" }
      ]
    }
  ]
}
{% endschema %}