{% capture content_params -%}{{ content_for_header }}{% endcapture %}
{% assign page_url = content_params | split: '"pageurl":"' | last | split: '"' | first | replace: '\/', '/' %}

{% if page_url contains 'day=' %}
  {% assign current_day_handle = page_url | split: 'day=' | last | split: '&' | first | strip %}
{% else %}
  {% assign current_day_handle = 'saturday' %}
{% endif %}

{% assign featured_collection = collections[current_day_handle] %}

<section class="full-width py-8 " data-section-id="{{ section.id }}">
  <!-- ১. ব্রেডক্রাম্ব -->
  <div class="px-6 md:px-12 py-4">
    <nav class="text-[10px] uppercase tracking-[0.2em] text-gray-500" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span class="mx-2">/</span>
      <span class="text-black font-bold">Modiweek</span>
    </nav>
  </div>

  <!-- ২. মেইন কন্টেন্ট (Featured Layout) -->
  <div class="flex flex-col md:flex-row px-6 md:px-12 items-start gap-8 lg:gap-16">
    <!-- বাম পাশ: কালেকশন টাইটেল ও ফিচার্ড ইমেজ -->
    <div>
      <h2 class="text-xl md:text-2xl font-semibold py-2 line-height:140% tracking-tight">
        {{ featured_collection.title | default: 'Saturday' }}
      </h2>

      <div class="w-full md:max-w-[350px] lg:w-[466px] xl:w-[496px] aspect-[3/4] overflow-hidden">
        {% if featured_collection.featured_image %}
          <img
            src="{{ featured_collection.featured_image | image_url: width: 1000 }}"
            alt="{{ featured_collection.title }}"
            class="w-full h-full object-cover"
            loading="eager"
          >
        {% else %}
          {{ 'collection-1' | placeholder_svg_tag: 'w-full h-full object-cover opacity-20' }}
        {% endif %}
      </div>
    </div>

    <!-- ডান পাশ: প্রোডাক্ট সেকশন (Limit 2) -->
    <div class="pt-4 md:pt-14 lg:pt-20 flex-1 w-full">
      <div class="flex justify-between">
        <div class="flex flex-col gap-1 mb-8 pb-4">
          <h3 class="text-lg font-bold uppercase tracking-wide">{{ featured_collection.title }} Items</h3>
          <p class="text-sm text-gray-600">{{ featured_collection.all_products_count }} items</p>
        </div>
        {% if featured_collection.all_products_count > 2 %}
          <div class="">
            <a
              href="{{ featured_collection.url }}"
              class="inline-block px-4 py-3  text-xs font-medium uppercase tracking-widest hover:bg-gray-100 transition-colors duration-300"
            >
              View All
            </a>
          </div>
        {% endif %}
      </div>

      <div class="flex justify-center flex-wrap md:gap-2 lg:gap-6">
        {% for product in featured_collection.products limit: 2 %}
          <div class="w-full md:max-w-[225px] lg:w-[290px]">
            {% render 'product-card', product: product %}
          </div>
        {% else %}
          <p class="text-gray-400">No products available in this collection.</p>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Modiweek Page Manager",
  "settings": [
    {
      "type": "paragraph",
      "content": "This section automatically pulls data based on the URL (?day=handle). Make sure your collections in the slider have correct handles."
    }
  ]
}
{% endschema %}
