  <section 
    id="cart-drawer"
    class="fixed top-[110px] right-0 w-[628px] h-full overflow-y-auto bg-[#F3F4F6] shadow-xl z-50 transform translate-x-full transition-transform duration-300 flex flex-col"
  >

    <!-- HEADER -->
    <div class="flex items-center justify-center py-4 relative border-b border-gray-100">
      <h1 class="text-h5 font-bold tracking-widest uppercase text-gray-800">Your Cart</h1>
      <button id="cart-close" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-700 text-xl leading-none cursor-pointer transition-colors">X</button>
    </div>

    {% if cart.item_count == 0 %}

    <!-- EMPTY STATE -->
    <div class="flex flex-col items-center justify-center flex-1 text-center px-8 pb-[10vh]">
      <h2 class="text-[16px] font-bold text-gray-900 mb-3">Your Shopping Bag Is Empty</h2>
      <p class="text-[13px] text-gray-600 mb-10 leading-[1.6]">
        Discover Modimal<br>
        And Add Products To Your Bag
      </p>
      <div class="flex flex-col items-center gap-[12px] w-full">
        <a href="{{ routes.all_products_collection_url }}" 
          class="bg-[#5A6D57] text-white w-[184px] h-[40px] flex items-center justify-center text-[13px] hover:bg-[#4a5c48] transition-colors">
          Collection
        </a>
        <a href="{{ routes.new_arrivals_collection_url | default: '/collections/all' }}" 
          class="bg-[#5A6D57] text-white w-[184px] h-[40px] flex items-center justify-center text-[13px] hover:bg-[#4a5c48] transition-colors">
          New In
        </a>
        <a href="{{ routes.best_sellers_collection_url | default: '/collections/all' }}" 
          class="bg-[#5A6D57] text-white w-[184px] h-[40px] flex items-center justify-center text-[13px] hover:bg-[#4a5c48] transition-colors">
          Best Sellers
        </a>
      </div>
    </div>

    {% else %}

    <!-- CART ITEMS -->
    <div class="flex-1 overflow-y-auto px-4">

      {% for item in cart.items %}
      <div class="h-[150px] flex gap-3.5 py-4 border-b border-gray-100 items-start">

        <!-- IMAGE -->
        <div class="relative flex-shrink-0">
          <img 
            src="{{ item.image | image_url: width: 200 }}" 
            alt="{{ item.title | escape }}"
            class="w-[100px] h-[130px] object-cover"
          >
          <span class="absolute top-1.5 right-1.5 bg-[#FFFFFF] text-black text-[10px] w-[24px] h-[24px] flex items-center justify-center font-medium">
            {{ item.quantity }}
          </span>
        </div>

        <!-- INFO -->
        <div class="flex-1 flex flex-col justify-between" style="min-height: 130px;">
          <div class="flex flex-col gap-2">
            <h2 class="text-[13px] font-semibold text-gray-900 mb-1">{{ item.product.title }}</h2>
            {% unless item.variant.title == 'Default Title' %}
              {% assign variant_parts = item.variant.title | split: ' / ' %}
              {% for part in variant_parts %}
                <p class="text-[11px] text-gray-400 leading-snug">
                  {% if forloop.index == 2 %}Size: {{ part }}
                  {% elsif forloop.index == 1 %}Color: {{ part }}
                  {% endif %}
                </p>
              {% endfor %}
            {% endunless %}
          </div>

          <!-- QTY + PRICE -->
          <div class="flex items-center justify-between">
            <div class="bg-[#D1D9CF] flex items-center h-7">
              <button 
                type="button" 
                class="w-7 h-7 flex items-center justify-center text-sm text-gray-700 hover:bg-black/5 transition-colors"
                data-action="decrease"
                data-key="{{ item.key }}"
                data-qty="{{ item.quantity }}"
              >−</button>
              <span class="text-[13px] font-medium text-gray-800 min-w-[20px] text-center">
                {{ item.quantity }}
              </span>
              <button 
                type="button"
                class="w-7 h-7 flex items-center justify-center text-sm text-gray-700 hover:bg-black/5 transition-colors"
                data-action="increase"
                data-key="{{ item.key }}"
                data-qty="{{ item.quantity }}"
              >+</button>
            </div>
            <p class="text-[13px] font-medium text-gray-900">
              {{ item.line_price | money }}
            </p>
          </div>
        </div>

        <!-- REMOVE -->
        <button 
          type="button"
          class="w-[22px] h-[22px] flex items-center justify-center text-gray-300 hover:text-gray-600 text-lg leading-none flex-shrink-0 mt-0.5 transition-colors"
          data-action="remove"
          data-key="{{ item.key }}"
        >×</button>

      </div>
      {% endfor %}


    {% endif %}

    <div class="bg-white flex justify-center items-center px-4 pt-3 pb-4 border-t border-gray-100">
      <a 
        id="cart-toggle-2"
        href="/cart"
        class="w-[392px] h-[40px] bg-[#5A6D57] text-white flex items-center justify-center"
      >
        <p class="text-[14px] font-regular">Check Out</p>
      </a>
    </div>

  </section>

 

  <script>
  document.addEventListener('DOMContentLoaded', function () {
    const cartDrawer = document.getElementById('cart-drawer');
    if (!cartDrawer) return;

    cartDrawer.addEventListener('click', function(e) {
      // Handle Close Button
      if (e.target.closest('#cart-close')) {
        if (window.toggleCartDrawer) {
          window.toggleCartDrawer(false);
        } else {
          cartDrawer.classList.add('translate-x-full');
        }
        return;
      }

      const btn = e.target.closest('button[data-action]');
      if (!btn) return;

      const action = btn.getAttribute('data-action');
      const key = btn.getAttribute('data-key');
      
      if (!key) return;

      let newQty = 0;
      if (action === 'increase') {
        newQty = parseInt(btn.getAttribute('data-qty')) + 1;
      } else if (action === 'decrease') {
        newQty = parseInt(btn.getAttribute('data-qty')) - 1;
        if (newQty < 0) newQty = 0;
      } else if (action === 'remove') {
        newQty = 0;
      }

      // Add loading state
      btn.style.opacity = '0.5';
      btn.style.pointerEvents = 'none';

      const routesRoot = window.Shopify && window.Shopify.routes ? window.Shopify.routes.root : '/';

      // Update cart
      fetch(routesRoot + 'cart/change.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          id: key,
          quantity: newQty
        })
      })
      .then(response => response.json())
      .then(cart => {
        // Update Header Cart Counts
        const desktopCartCount = document.getElementById('desktop-cart-count');
        if (desktopCartCount) {
          desktopCartCount.textContent = cart.item_count;
          if (cart.item_count === 0) {
            desktopCartCount.classList.add('hidden');
          } else {
            desktopCartCount.classList.remove('hidden');
          }
        }
        
        const mobileCartCount = document.getElementById('mobile-cart-count');
        if (mobileCartCount) {
          mobileCartCount.textContent = cart.item_count;
        }

        // Refetch current page to get updated cart drawer HTML
        return fetch(window.location.pathname + window.location.search);
      })
      .then(res => res.text())
      .then(text => {
        const parser = new DOMParser();
        const html = parser.parseFromString(text, 'text/html');
        const updatedDrawer = html.getElementById('cart-drawer');
        
        if (updatedDrawer) {
          cartDrawer.innerHTML = updatedDrawer.innerHTML;
        }
      })
      .catch(error => {
        console.error('Error updating cart:', error);
        btn.style.opacity = '1';
        btn.style.pointerEvents = 'auto';
      });
    });
  });

  
document.getElementById('cart-toggle-2').addEventListener('click', function() {
  document.getElementById('cart-drawer').classList.remove('translate-x-full');
});

</script>