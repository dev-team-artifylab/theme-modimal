<form id="CollectionFiltersForm" class="flex flex-col gap-6">

  <!-- Header -->
  <div>
    <h2 class="text-xl font-semibold">Filters</h2>
  </div>

  <!-- Actions -->
  <div class="flex items-center justify-between">
    <a href="{{ collection.url }}" class="text-sm underline text-gray-500">
      Clear all
    </a>

    <button
      type="submit"
      class="flex items-center justify-center gap-1 w-[184px] h-[40px] px-4 bg-[#5A6D57] text-white text-sm font-medium rounded-md hover:opacity-90 transition"
    >
      Apply Filters →
    </button>
  </div>

  <!-- Filters -->
  <div class="flex flex-col gap-4">

  {% for filter in collection.filters %}
    <div class="filter-item rounded-md transition">

      <!-- Header -->
      <button
        type="button"
        class="filter-toggle flex items-center justify-between w-full h-[48px] px-4 bg-[#748C70] text-white text-[16px] font-bold rounded-md transition"
      >
        {{ filter.label }}
        <span class="icon text-lg">+</span>
      </button>

      <!-- Content -->
      <div class="filter-content hidden mt-2 px-4 pb-4 space-y-2">

        {% for value in filter.values %}
          <label class="flex items-center justify-between text-[16px] text-regular font-regular">

            <div class="flex items-center gap-2">
              <input
                type="checkbox"
                name="{{ filter.param_name }}"
                value="{{ value.value }}"
                {% if value.active %}checked{% endif %}
                class="accent-[#A2B39F]"
              >
              <span>{{ value.label }}</span>
            </div>

            <span class="text-gray-400">
              ({{ value.count }})
            </span>

          </label>
        {% endfor %}

      </div>

    </div>
  {% endfor %}

</div>

</form>