<nav aria-label="Social Media">
  <ul class="flex items-center gap-4">
    {% if settings.social_instagram_link != blank %}
      <li>
        <a
          href="{{ settings.social_instagram_link }}"
          aria-label="Instagram"
          class="text-white hover:text-white transition-colors duration-300"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5">
            <path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2zm0 1.5A4.25 4.25 0 0 0 3.5 7.75v8.5A4.25 4.25 0 0 0 7.75 20.5h8.5a4.25 4.25 0 0 0 4.25-4.25v-8.5A4.25 4.25 0 0 0 16.25 3.5h-8.5zM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm0 1.5A3.5 3.5 0 1 0 12 15.5 3.5 3.5 0 0 0 12 8.5zm5.25-2.25a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5z"/>
          </svg>
        </a>
      </li>
    {% endif %}

    {% if settings.social_facebook_link != blank %}
      <li>
        <a
          href="{{ settings.social_facebook_link }}"
          aria-label="Facebook"
          class="text-white hover:text-white transition-colors duration-300"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5">
            <path d="M13.5 22v-8h2.7l.4-3h-3.1V9.1c0-.9.3-1.6 1.6-1.6H17V4.8c-.4-.1-1.5-.1-2.7-.1-2.7 0-4.5 1.6-4.5 4.7V11H7v3h2.8v8h3.7z"/>
          </svg>
        </a>
      </li>
    {% endif %}

    {% if settings.social_pinterest_link != blank %}
      <li>
        <a
          href="{{ settings.social_pinterest_link }}"
          aria-label="Pinterest"
          class="text-white hover:text-white transition-colors duration-300"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5">
            <path d="M12 2a10 10 0 0 0-3.6 19.3c0-.8 0-2 .1-2.9l1.3-5.5s-.3-.6-.3-1.5c0-1.4.8-2.5 1.9-2.5.9 0 1.3.7 1.3 1.5 0 .9-.6 2.3-.9 3.6-.2 1 .5 1.8 1.5 1.8 1.8 0 3.1-1.9 3.1-4.6 0-2.4-1.7-4-4.2-4-2.9 0-4.6 2.2-4.6 4.4 0 .9.3 1.8.8 2.3.1.1.1.2.1.4l-.3 1.2c0 .2-.2.3-.4.2-1.4-.6-2.2-2.5-2.2-4 0-3.2 2.4-6.2 6.8-6.2 3.6 0 6.4 2.6 6.4 6 0 3.6-2.3 6.5-5.4 6.5-1.1 0-2.1-.6-2.5-1.3l-.7 2.5c-.2.8-.8 1.9-1.2 2.5.9.3 1.8.5 2.8.5A10 10 0 0 0 12 2z"/>
          </svg>
        </a>
      </li>
    {% endif %}

    {% if settings.social_tiktok_link != blank %}
      <li>
        <a
          href="{{ settings.social_tiktok_link }}"
          aria-label="TikTok"
          class="text-white hover:text-white transition-colors duration-300"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5">
            <path d="M16.5 2c.3 2.1 1.5 3.8 3.5 4.3v3c-1.5 0-2.9-.5-4-1.4v6.5c0 3.3-2.7 6-6 6s-6-2.7-6-6 2.7-6 6-6c.4 0 .8 0 1.2.1v3.2c-.4-.1-.8-.2-1.2-.2-1.6 0-2.8 1.3-2.8 2.9s1.2 2.9 2.8 2.9 2.8-1.3 2.8-2.9V2h3.7z"/>
          </svg>
        </a>
      </li>
    {% endif %}
  </ul>
</nav>