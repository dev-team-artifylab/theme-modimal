{%- assign collection = collections[collection_handle] -%}

<div class="relative w-full {{ aspect_ratio }} bg-[#f3f3f3] overflow-hidden group">
  {%- if collection.featured_image != blank -%}
    {{
      collection.featured_image
      | image_url: width: 1000
      | image_tag:
        class: 'w-full h-full object-cover transition-transform duration-500 group-hover:scale-105',
        loading: 'lazy',
        alt: collection.featured_image.alt
      | default: collection.title
    }}
  {%- else -%}
    {{ 'collection-1' | placeholder_svg_tag: 'w-full h-full object-cover' }}
  {%- endif -%}

  <a
    href="{{ collection.url | default: '#' }}"
    class="absolute bottom-6 right-6 bg-white text-black px-6 py-2 text-xs md:text-sm uppercase tracking-wider hover:bg-black hover:text-white transition-all shadow-sm"
  >
    {{ collection.title | default: 'Select Collection' }}
  </a>
</div>
