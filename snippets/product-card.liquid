<article class="product-card group flex flex-col w-full h-full bg-white">
  {% comment %} 1. Product Image & Wishlist {% endcomment %}
  <div class="relative w-full aspect-[3/3.8] overflow-hidden rounded-lg bg-[#f3f3f3]">
    <a href="{{ product.url }}" class="block w-full h-full" aria-label="View {{ product.title }}">
      {% if product.featured_image %}
        <img
          src="{{ product.featured_image | image_url: width: 800 }}"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          width="{{ product.featured_image.width }}"
          height="{{ product.featured_image.height }}"
          loading="lazy"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        >
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover opacity-30' }}
      {% endif %}
    </a>

    <button
      type="button"
      class="absolute top-3 right-3 md:top-4 md:right-4 z-10 flex items-center justify-center w-8 h-8 md:w-10 md:h-10 rounded-full bg-white/90 backdrop-blur-sm shadow-sm hover:bg-white hover:scale-110 transition-all"
      aria-label="Add {{ product.title }} to Wishlist"
      data-product-handle="{{ product.handle }}"
    >
      <svg
        class="w-5 h-5 text-black pointer-events-none"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        viewBox="0 0 24 24"
      >
        <path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
      </svg>
    </button>
  </div>

  {% comment %} 2. Product Information Section {% endcomment %}
  <div class="flex flex-col p-2 flex-1">
    <div class="flex justify-between items-center">
      <div class="flex flex-col gap-1 flex-1 min-w-0 gap-4">
        <p class="text-[10px] md:text-xs font-bold text-gray-600 uppercase tracking-widest">
          {{ product.type | default: 'Collection' }}
        </p>

        <h3 class="text-sm md:text-base font-normal text-gray-800 leading-tight">
          <a href="{{ product.url }}" class="hover:underline underline-offset-4">
            {{ product.title | split: ' ' | slice: 0, 3 | join: ' ' }}
          </a>
        </h3>

        {% comment %} Color Swatches with Safety Check {% endcomment %}
        <div class="flex flex-wrap gap-2 mt-2 min-h-[24px]">
          {% for option in product.options_with_values %}
            {% assign option_name = option.name | downcase %}
            {% if option_name contains 'color' or option_name contains 'colour' %}
              {% for value in option.values %}
                {%- comment -%} CSS inline color support for multi-word colors {%- endcomment -%}
                {% assign color_value = value | split: ' ' | last | handle %}
                <span
                  class="w-4 h-4 md:w-5 md:h-5 rounded-full border border-gray-200"
                  style="background-color: {{ color_value }};"
                  title="{{ value }}"
                ></span>
              {% endfor %}
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="shrink-0 pt-4">
        <span class="text-sm md:text-base font-semibold text-gray-900">
          {{ product.price | money }}
        </span>
      </div>
    </div>
  </div>
</article>
