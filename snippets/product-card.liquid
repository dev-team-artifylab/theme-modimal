<div class="product-card group w-full h-[540px] flex flex-col border border-gray-100 rounded-lg overflow-hidden bg-white">
  
  {% comment %} Product Image + Wishlist {% endcomment %}
  <div class="relative w-full h-[360px] overflow-hidden flex-shrink-0">
    <a href="{{ product.url }}" class="block w-full h-full">
      <img
        src="{{ product.featured_image | image_url: width: 900 }}"
        alt="{{ product.title | escape }}"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      >
    </a>

    {% comment %} Wishlist Button {% endcomment %}
    <button
      class="wishlist-btn absolute top-4 right-4 z-10 flex items-center justify-center w-9 h-9 md:w-10 md:h-10 rounded-full bg-white/90 backdrop-blur-sm shadow-sm hover:scale-110 transition-transform"
      aria-label="Add to Wishlist"
      data-product-id="{{ product.id }}"
    >
      <svg class="w-5 h-5 md:w-6 md:h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
      </svg>
    </button>
  </div>

  {% comment %} Product Details Section {% endcomment %}
  <div class="flex flex-col flex-1 p-5">
    
    <div class="flex items-start justify-between gap-4">
      <div class="flex-1 min-w-0">
        <p class="text-[15px] font-bold text-[#111111] leading-tight">{{ product.type }}</p>
        <h3 class="mt-2 text-[15px] font-normal text-[#666666] leading-relaxed line-clamp-2">
          {{ product.title }}
        </h3>
      </div>
      <div class="shrink-0 flex items-center justify-center min-w-[90px]">
        <span class="text-[20px] font-bold text-[#111111] whitespace-nowrap">
          {{ product.price | money }}
        </span>
      </div>
    </div>

    {% comment %} Color Swatches (mt-auto ensures they stay at the bottom) {% endcomment %}
    <div class="flex items-center gap-3 mt-auto pt-4">
      {% for option in product.options_with_values %}
        {% if option.name == 'Color' %}
          {% for value in option.values limit: 4 %}
            <button
              class="w-7 h-7 rounded-full border border-[#D1D5DB] shadow-sm hover:scale-110 transition-transform"
              style="background-color: {{ value | handle }};"
              aria-label="Select {{ value }}"
            ></button>
          {% endfor %}
        {% endif %}
      {% endfor %}
    </div>
    
  </div>
</div>