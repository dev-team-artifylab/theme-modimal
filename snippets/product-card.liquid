<div class="product-card group w-full h-full flex flex-col border border-gray-100 rounded-lg overflow-hidden bg-white">
  
  <div class="relative w-full aspect-[4/3] overflow-hidden flex-shrink-0">
    <a href="{{ product.url }}" class="block w-full h-full">
      <img
        src="{{ product.featured_image | image_url: width: 900 }}"
        alt="{{ product.title | escape }}"
        class="w-full h-full object-cover"
        loading="lazy"
      >
    </a>
  </div>

  <div class="flex flex-col flex-1 p-5">
    
    <div class="flex-1">
        <p class="text-[15px] font-bold text-[#111111] leading-tight">{{ product.type }}</p>
        <h3 class="mt-2 text-[15px] font-normal text-[#666666] leading-relaxed line-clamp-2">
          {{ product.title }}
        </h3>
    </div>

    <div class="mt-4">
        <div class="mb-4">
            <span class="text-[20px] font-bold text-[#111111]">{{ product.price | money }}</span>
        </div>
        
        <div class="flex items-center gap-3">
          {% for option in product.options_with_values %}
            {% if option.name == 'Color' %}
              {% for value in option.values limit: 4 %}
                <button class="w-7 h-7 rounded-full border border-[#D1D5DB] bg-[{{ value | handle }}]"></button>
              {% endfor %}
            {% endif %}
          {% endfor %}
        </div>
    </div>
    
  </div>
</div>